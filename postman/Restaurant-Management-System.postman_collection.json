{
  "info": {
    "name": "Restaurant Management System",
    "_postman_id": "63e2f129-c5e3-40e3-8c59-restaurant-rms",
    "description": "Postman collection for Restaurant Management System APIs",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "adminUserId",
      "value": "admin-user-1"
    },
    {
      "key": "adminRole",
      "value": "ADMIN"
    },
    {
      "key": "userUserId",
      "value": "user-rahul-1"
    },
    {
      "key": "userRole",
      "value": "USER"
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"testuser@restaurant.com\",\n  \"password\": \"password123\",\n  \"role\": \"USER\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "register"
              ]
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@restaurant.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Menu Items",
      "item": [
        {
          "name": "Get Menu Items",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/menu-items",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "menu-items"
              ]
            }
          }
        },
        {
          "name": "Create Menu Item (Admin)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-USER-ID",
                "value": "{{adminUserId}}"
              },
              {
                "key": "X-USER-ROLE",
                "value": "{{adminRole}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Paneer Tikka\",\n  \"price\": 229,\n  \"category\": \"Starter\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/menu-items",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "menu-items"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Create Order (User)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-USER-ID",
                "value": "{{userUserId}}"
              },
              {
                "key": "X-USER-ROLE",
                "value": "{{userRole}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"items\": [\n    {\n      \"menuItemId\": \"menu-1\",\n      \"quantity\": 1\n    },\n    {\n      \"menuItemId\": \"menu-4\",\n      \"quantity\": 2\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/orders",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "orders"
              ]
            }
          }
        },
        {
          "name": "Get Orders",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-USER-ID",
                "value": "{{userUserId}}"
              },
              {
                "key": "X-USER-ROLE",
                "value": "{{userRole}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/orders",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "orders"
              ]
            }
          }
        },
        {
          "name": "Update Order Status (Admin)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-USER-ID",
                "value": "{{adminUserId}}"
              },
              {
                "key": "X-USER-ROLE",
                "value": "{{adminRole}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"COMPLETED\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/orders/1/status",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "orders",
                "1",
                "status"
              ]
            }
          }
        }
      ]
    }
  ]
}
